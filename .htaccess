<IfModule mod_passenger.c>
	PassengerEnabled off
</IfModule>

RewriteEngine On

# Explicitly disable favicon serving to avoid repeated browser requests causing server errors
RewriteRule ^favicon\.ico$ - [R=204,L]

# 0) CRITICAL: Skip rewrite for any existing file or directory (MUST be first)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 1) Force HTTPS (optional if SSL installed)
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2) Redirect any *.html URL to clean URL
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^([^.]+)\.html$ /$1 [R=301,L]

# 4) Internally rewrite clean URLs to existing .html files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
