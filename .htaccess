RewriteEngine On

# 0) CRITICAL: Skip rewrite for any existing file or directory (MUST be first)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Serve the real static favicon only when no physical favicon file exists
RewriteRule ^favicon\.ico$ /assets/img/logo.svg [L]

# 1) Force HTTPS (optional if SSL installed)
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2) Redirect any *.html URL to clean URL
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^([^.]+)\.html$ /$1 [R=301,L]

# 3) Internally rewrite clean URLs to existing .html files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
